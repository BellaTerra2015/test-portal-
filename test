function saveTruck(targetCount){
  const j = currentSJJob;
  if(!j.trucks) j.trucks=[];
  const truckId = document.getElementById('tk-id').value.trim()||'Truck '+(j.trucks.length+1);
  const loadNum = document.getElementById('tk-loadnum').value||String(j.trucks.length+1);
  const driver = document.getElementById('tk-driver').value.trim();
  const items = [];
  const targets = j.targets||[];

  for(let i=0;i<targetCount;i++){
    const qtyEl = document.getElementById('tk-qty-'+i);
    const srcEl = document.getElementById('tk-src-'+i);
    const vendEl = document.getElementById('tk-vendor-'+i);
    const qty = parseInt(qtyEl?.value)||0;
    if(!qty) continue;
    const t = targets[i];
    items.push({spId:t.spId,container:t.container,qty,source:srcEl?.value||'nursery',vendorName:vendEl?.value||''});
  }

  if(!items.length){alert('Add at least one species with a qty.');return;}

  j.trucks.push({id:'tk_'+Date.now(),truckId,loadNum,driver,items,shipped:false,shippedDate:''});
  saveSJJob();
  document.getElementById('m-addtruck').classList.remove('open');
  renderSJStep('pullsheet',document.getElementById('sj-step-pullsheet'));
}

function removeTruckItem(ti,ii){
  if(!confirm('Remove this item?')) return;
  currentSJJob.trucks[ti].items.splice(ii,1);
