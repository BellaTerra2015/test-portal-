function saveInspPhoto2(spId,type,e){
  const file=e.target.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=ev=>{
    if(!currentSJJob.inspectionData) currentSJJob.inspectionData={ourCount:[],inspectorCount:[],photos:{}};
    if(!currentSJJob.inspectionData.photos) currentSJJob.inspectionData.photos={};
    if(!currentSJJob.inspectionData.photos[spId]) currentSJJob.inspectionData.photos[spId]={};
    currentSJJob.inspectionData.photos[spId][type]=ev.target.result;
    saveSJJob();
    renderSJStep('inspection',document.getElementById('sj-step-inspection'));
  };reader.readAsDataURL(file);
}
function clearInspPhoto(spId,type){
  if(currentSJJob.inspectionData?.photos?.[spId]) delete currentSJJob.inspectionData.photos[spId][type];
  saveSJJob();renderSJStep('inspection',document.getElementById('sj-step-inspection'));
}
function saveInspCount(spId,who,val){
  if(!currentSJJob.inspectionData) currentSJJob.inspectionData={ourCount:[],inspectorCount:[],photos:{}};
  const arr=who==='inspector'?currentSJJob.inspectionData.inspectorCount:currentSJJob.inspectionData.ourCount;
  if(!Array.isArray(arr)){currentSJJob.inspectionData[who==='inspector'?'inspectorCount':'ourCount']=[];}
  const existing=(currentSJJob.inspectionData[who==='inspector'?'inspectorCount':'ourCount']||[]).find(c=>c.spId===spId);
  if(existing) existing.qty=val;
  else (currentSJJob.inspectionData[who==='inspector'?'inspectorCount':'ourCount']=[...(currentSJJob.inspectionData[who==='inspector'?'inspectorCount':'ourCount']||[]),{spId,qty:val}]);
  saveSJJob();
}
