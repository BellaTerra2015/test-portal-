}

function deleteStockEntry(entryId, commonName, qty){
  if(!nurseryEditMode){nToast('🔒 Unlock edit mode first');return;}
  if(!confirm(`Delete ${qty} ${commonName} from inventory?\n\nThis cannot be undone.`))return;
  stock=stock.filter(e=>e.id!==entryId);
  sv(SK.stock,stock);
  nToast(`🗑 Deleted ${qty} ${commonName}`);
  buildInv();buildDash();
}

function checkDuplicate(){
  const spId=document.getElementById('as-sp')?.value;const cont=document.getElementById('as-cont')?.value;const loc=document.getElementById('as-loc')?.value;
  const el=document.getElementById('as-dup-warn');if(!el||!spId||!cont||!loc)return;
  const existing=stock.find(e=>e.spId===spId&&e.container===cont&&e.location===loc);
  if(existing){const sp=spById(spId);el.innerHTML=`<div style="background:var(--amber-lt);border:2px solid var(--amber3);border-radius:var(--r8);padding:12px;margin-bottom:10px">⚠️ <b>Existing entry:</b> ${sp.common} ${cont} at ${LOC_LABELS[loc]} already has <b>${existing.qty}</b> plants. This will add a new row.</div>`;}
  else el.innerHTML='';
}

function saveStock(){
  if(!nurseryEditMode){nToast('🔒 Unlock edit mode first');return;}
  const spId=document.getElementById('as-sp').value;if(!spId){nToast('Select a species');return;}
  const qty=parseInt(document.getElementById('as-qty').value)||0;if(qty<=0){nToast('Enter qty > 0');return;}
  const cont=document.getElementById('as-cont').value;
  const loc=document.getElementById('as-loc').value;
  const origin=document.getElementById('as-origin').value;
  const jobAlloc=document.getElementById('as-job').value;
  const notes=document.getElementById('as-notes').value;
  const dateVal=document.getElementById('as-date').value||nToday();

  // If bare root or plug — offer potting queue or keep as-is
  if(cont==='bare root'||cont==='plug'||cont==='4in'||cont==='live stake'){
    const sp=spById(spId);
    const choice=confirm(`"${sp.common}" added as ${cont}.\n\nTap OK to also add to the Potting Queue (recommended for bare root/plug).\nTap Cancel to keep as inventory only.`);
    const entry={id:'stk_'+Date.now(),spId,container:cont,qty,location:loc,origin,dateAdded:dateVal,notes,jobAlloc};
    stock.push(entry);sv(SK.stock,stock);
    if(choice){
      // Add to potting queue
      const pruneF=getPruneFlag(spId,jobAlloc);
      const calF=getCaliperFlag(spId,jobAlloc);
      const targetCont=calF.flag?'check':'#1';
      const existing=pottingQueue.find(o=>o.id==='manual_queue');
      if(existing){
        // Add to existing manual queue batch
        const existItem=existing.items.find(i=>i.spId===spId&&i.targetContainer===targetCont);
        if(existItem)existItem.qtyReceived+=qty;
        else existing.items.push({spId,qtyReceived:qty,qtyPotted:0,targetContainer:targetCont,pruneFlag:pruneF.flag?pruneF:null,caliperFlag:calF.flag?calF:null,notes:''});
        svPQ();
      } else {
        pottingQueue.unshift({id:'manual_queue',vendor:'Manual Entry',invoiceNum:'Hand-entered',invoiceDate:dateVal,jobAlloc,receivedDate:dateVal,status:'heeled',items:[
          {spId,qtyReceived:qty,qtyPotted:0,targetContainer:targetCont,pruneFlag:pruneF.flag?pruneF:null,caliperFlag:calF.flag?calF:null,notes:''}
        ]});svPQ();
      }
      nToast(`✅ ${qty} ${sp.common} added to inventory + Potting Queue`);
    } else {
      nToast(`✅ ${qty} ${spById(spId).common} added to inventory`);
    }
  } else {
    const entry={id:'stk_'+Date.now(),spId,container:cont,qty,location:loc,origin,dateAdded:dateVal,notes,jobAlloc};
    stock.push(entry);sv(SK.stock,stock);
    nToast('✅ '+qty+' '+spById(spId).common+' added');
  }
  closeM('m-addstock');buildInv();buildDash();
}

