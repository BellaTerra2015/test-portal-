<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bella Terra Employee Portal</title>
<meta name="theme-color" content="#2d5a27">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="BT Portal">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icon-192.png">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Source+Sans+3:wght@300;400;600&family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ── PORTAL BASE ── */
:root {
  --green-dark:#2d5a27;--green-mid:#4a7c3f;--green-light:#7ab648;
  --green-pale:#e8f5e2;--blue-accent:#1a6b8a;--gold:#c8961e;
  --white:#ffffff;--gray-light:#f5f5f2;--gray-mid:#888;
  --text:#2a2a2a;--border:#d0dcc8;--red:#c0392b;
  --shadow:0 2px 12px rgba(45,90,39,0.10);
  --orange-dark:#b85c00;--orange-light:#fff3e8;--orange-border:#e07c30;
  /* nursery vars */
  --ink:#18170F;--ink2:#3A3929;--ink3:#6A6858;--ink4:#9A9884;
  --paper:#F7F4EC;--paper2:#EEEADF;--paper3:#E4E0D3;
  --green:#1E4D0F;--green2:#2E6E18;--green3:#4A9425;--green-lt:#EBF5DE;
  --amber:#7A3E05;--amber2:#B85C0A;--amber3:#E87C1A;--amber-lt:#FDF1DC;
  --red2:#C0271B;--red3:#E84B3A;--red-lt:#FDEAEA;
  --blue:#0A3260;--blue2:#1255A8;--blue3:#3D7FD4;--blue-lt:#E5EEFB;
  --gld:#8B6914;--gold2:#C49A1E;--gold3:#F0C040;--gold-lt:#FDF8E1;
  --brd:#CCC9B8;--brd2:#E0DDD0;
  --r4:4px;--r6:6px;--r8:8px;--r12:12px;
  --shd:0 1px 3px rgba(0,0,0,.08);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Source Sans 3',sans-serif;background:var(--gray-light);color:var(--text);min-height:100vh;}
button,input,select,textarea{font-family:inherit;}

/* ── LOGIN ── */
#login-screen{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;background:linear-gradient(160deg,var(--green-dark) 0%,var(--green-mid) 60%,var(--green-light) 100%);padding:2rem;}
#login-screen h1{font-family:'Playfair Display',serif;color:#fff;font-size:2rem;margin-bottom:0.25rem;text-align:center;}
#login-screen p{color:rgba(255,255,255,0.75);margin-bottom:2rem;text-align:center;}
.login-box{background:white;border-radius:12px;padding:2rem;width:100%;max-width:380px;box-shadow:0 8px 40px rgba(0,0,0,0.25);}
.login-box label{display:block;font-weight:600;font-size:0.85rem;color:var(--green-dark);margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.05em;}
.login-box input{width:100%;padding:0.75rem 1rem;border:2px solid var(--border);border-radius:8px;font-size:1rem;margin-bottom:1rem;transition:border-color 0.2s;}
.login-box input:focus{outline:none;border-color:var(--green-mid);}
.btn-primary{width:100%;padding:0.85rem;background:var(--green-dark);color:white;border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer;transition:background 0.2s;}
.btn-primary:hover{background:var(--green-mid);}
.error-msg{color:var(--red);font-size:0.875rem;margin-top:0.5rem;display:none;}

/* ── PORTAL SHELL ── */
#portal{display:none;min-height:100vh;}
.portal-header{background:var(--green-dark);padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;box-shadow:0 2px 8px rgba(0,0,0,0.2);}
.portal-header h2{font-family:'Playfair Display',serif;color:white;font-size:1.2rem;}
.header-right{display:flex;align-items:center;gap:1rem;}
.employee-badge{background:rgba(255,255,255,0.15);color:white;padding:0.3rem 0.75rem;border-radius:20px;font-size:0.85rem;}
.btn-logout{background:transparent;color:rgba(255,255,255,0.7);border:1px solid rgba(255,255,255,0.3);padding:0.3rem 0.75rem;border-radius:6px;cursor:pointer;font-size:0.85rem;transition:all 0.2s;}
.btn-logout:hover{background:rgba(255,255,255,0.1);color:white;}

/* ── PORTAL TILES ── */
.portal-main{padding:2rem 1.5rem;max-width:960px;margin:0 auto;}
.portal-welcome{text-align:center;margin-bottom:2rem;}
.portal-welcome h3{font-family:'Playfair Display',serif;font-size:1.8rem;color:var(--green-dark);margin-bottom:0.5rem;}
.portal-welcome p{color:var(--gray-mid);font-size:0.95rem;}
.tiles-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.5rem;margin-bottom:2rem;}
.tile{background:white;border-radius:14px;padding:2rem 1.5rem;box-shadow:var(--shadow);cursor:pointer;transition:transform 0.2s,box-shadow 0.2s;border:2px solid transparent;text-decoration:none;color:var(--text);display:block;text-align:center;}
.tile:hover{transform:translateY(-4px);box-shadow:0 8px 24px rgba(45,90,39,0.18);border-color:var(--green-light);}
.tile-icon{font-size:3rem;margin-bottom:1rem;}
.tile h3{font-family:'Playfair Display',serif;font-size:1.3rem;color:var(--green-dark);margin-bottom:0.4rem;}
.tile p{font-size:0.85rem;color:var(--gray-mid);line-height:1.5;}
.tile.has-badge{position:relative;}
.tile-badge{position:absolute;top:1rem;right:1rem;background:var(--red);color:white;font-size:0.7rem;font-weight:700;padding:0.2rem 0.5rem;border-radius:10px;}

/* ── MODALS (portal) ── */
.p-modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.55);z-index:999;align-items:center;justify-content:center;}
.p-modal.open{display:flex;}
.p-modal-box{background:white;border-radius:16px;padding:2rem;width:90%;max-width:580px;max-height:85vh;overflow-y:auto;box-shadow:0 12px 48px rgba(0,0,0,0.3);}
.omw-box{background:white;border-radius:16px;width:92%;max-width:480px;max-height:92vh;overflow-y:auto;box-shadow:0 16px 56px rgba(0,0,0,0.35);padding:2rem;}
.omw-closer{background:transparent;border:none;font-size:1.6rem;cursor:pointer;color:var(--gray-mid);line-height:1;float:right;}
.omw-field{width:100%;padding:0.6rem 0.75rem;border:2px solid var(--border);border-radius:7px;font-size:0.95rem;margin-top:0.3rem;box-sizing:border-box;}
.omw-field:focus{outline:none;border-color:var(--green-mid);}
.omw-label{font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;display:block;margin-bottom:0.2rem;}
.omw-preview{background:#f5f5f2;border-radius:10px;padding:1rem;margin:1rem 0;font-size:0.88rem;color:#444;line-height:1.6;}
.omw-send-btn{width:100%;padding:0.9rem;border:none;border-radius:10px;font-size:1rem;font-weight:700;cursor:pointer;color:white;margin-top:0.5rem;}
.omw-back{background:none;border:none;color:#888;cursor:pointer;font-size:0.9rem;margin-bottom:1rem;padding:0;}
.omw-success{background:#eaf7ea;border:1px solid var(--green-light);border-radius:10px;padding:1.5rem;text-align:center;margin-top:1rem;}
.omw-result-card{border:2px solid var(--border);border-radius:10px;padding:1rem;margin-bottom:0.75rem;cursor:pointer;transition:all 0.15s;}
.omw-result-card:hover{border-color:#7ab648;background:var(--green-pale);}

/* ── REORDER ── */
#reorder-modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.65);z-index:1100;align-items:center;justify-content:center;}
#reorder-modal.open{display:flex;}
.reorder-box{background:white;border-radius:16px;padding:2rem;width:92%;max-width:660px;max-height:90vh;overflow-y:auto;box-shadow:0 16px 56px rgba(0,0,0,0.35);}
.reorder-box h3{font-family:'Playfair Display',serif;font-size:1.4rem;color:var(--green-dark);margin-bottom:0.25rem;}
.reorder-sub{font-size:0.83rem;color:var(--gray-mid);margin-bottom:1.25rem;}
.reorder-top-bar{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1rem;}
.reorder-job-wrap{display:flex;flex-direction:column;gap:0.3rem;flex:1;margin-right:1rem;}
.reorder-job-wrap label{font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--green-dark);}
.reorder-job-wrap input{padding:0.6rem 0.85rem;border:2px solid var(--border);border-radius:7px;font-size:0.95rem;transition:border-color 0.2s;}
.reorder-closer{background:transparent;border:none;font-size:1.6rem;cursor:pointer;color:var(--gray-mid);line-height:1;flex-shrink:0;}
.reorder-item{border:2px solid var(--border);border-radius:10px;padding:1rem 1.1rem;margin-bottom:0.85rem;transition:border-color 0.2s,background 0.2s;}
.reorder-item.selected{border-color:var(--green-mid);background:var(--green-pale);}
.reorder-item-top{display:flex;align-items:center;gap:0.75rem;cursor:pointer;}
.reorder-item-top input[type="checkbox"]{width:18px;height:18px;flex-shrink:0;accent-color:var(--green-dark);cursor:pointer;}
.reorder-item-name{font-weight:600;font-size:0.95rem;flex:1;}
.reorder-item-vendor{font-size:0.78rem;color:var(--gray-mid);white-space:nowrap;}
.reorder-item-details{display:none;margin-top:0.85rem;padding-top:0.85rem;border-top:1px solid var(--border);}
.reorder-item.selected .reorder-item-details{display:block;}
.last-order-badge{display:inline-block;background:rgba(74,124,63,0.12);color:var(--green-dark);font-size:0.8rem;font-weight:600;border-radius:5px;padding:0.28rem 0.65rem;margin-bottom:0.75rem;}
.reorder-detail-row{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:0.75rem;}
.reorder-detail-row .form-group label{color:var(--green-dark);font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;}
.reorder-detail-row .form-group input{padding:0.55rem 0.75rem;border:2px solid var(--border);border-radius:6px;font-size:0.9rem;background:white;width:100%;}
.reorder-notes label{font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--green-dark);display:block;margin-bottom:0.3rem;}
.reorder-notes textarea{width:100%;padding:0.55rem 0.75rem;border:2px solid var(--border);border-radius:6px;font-size:0.88rem;resize:vertical;min-height:58px;}
.reorder-footer{display:flex;gap:0.75rem;margin-top:1.5rem;flex-wrap:wrap;}
.btn-reorder-submit{padding:0.8rem 1.75rem;background:var(--green-dark);color:white;border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer;}
.btn-reorder-cancel{padding:0.8rem 1.25rem;background:transparent;color:var(--gray-mid);border:2px solid var(--border);border-radius:8px;font-size:1rem;cursor:pointer;}
.reorder-success{display:none;background:#eaf7ea;border:1px solid var(--green-light);border-radius:8px;padding:1rem 1.25rem;color:var(--green-dark);font-weight:600;margin-top:1rem;font-size:0.92rem;line-height:1.65;}
.reorder-success.show{display:block;}

/* ── EMPLOYEE RESOURCES ── */
#panel-resources{display:none;}
.panel-header{background:var(--green-dark);color:white;padding:1rem 1.5rem;display:flex;align-items:center;gap:1rem;}
.btn-back{background:transparent;color:rgba(255,255,255,0.8);border:1px solid rgba(255,255,255,0.3);padding:0.4rem 0.85rem;border-radius:6px;cursor:pointer;font-size:0.85rem;}
.panel-header h3{font-family:'Playfair Display',serif;font-size:1.2rem;}
.panel-content{padding:1.5rem;max-width:860px;margin:0 auto;}
.res-nav{background:white;border-bottom:2px solid var(--border);display:flex;overflow-x:auto;padding:0 1rem;margin-bottom:1.5rem;border-radius:10px 10px 0 0;box-shadow:var(--shadow);}
.res-tab{padding:1rem 1.25rem;font-size:0.9rem;font-weight:600;color:var(--gray-mid);background:transparent;border:none;border-bottom:3px solid transparent;cursor:pointer;white-space:nowrap;transition:all 0.2s;margin-bottom:-2px;}
.res-tab:hover{color:var(--green-mid);}
.res-tab.active{color:var(--green-dark);border-bottom-color:var(--green-dark);}
.res-tab .badge{background:var(--red);color:white;font-size:0.7rem;padding:0.1rem 0.4rem;border-radius:10px;margin-left:0.4rem;vertical-align:middle;}
.sub-panel{display:none;}.sub-panel.active{display:block;}
.welcome-card{background:linear-gradient(135deg,var(--green-dark),var(--green-mid));border-radius:12px;padding:1.75rem;color:white;margin-bottom:1.5rem;}
.welcome-card h3{font-family:'Playfair Display',serif;font-size:1.5rem;margin-bottom:0.5rem;}
.welcome-card p{opacity:0.85;line-height:1.6;}
.tasks-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1rem;margin-bottom:1.5rem;}
.task-card{background:white;border-radius:10px;padding:1.25rem;border-left:4px solid var(--border);box-shadow:var(--shadow);cursor:pointer;transition:transform 0.15s;}
.task-card.required{border-left-color:var(--red);}
.task-card.annual{border-left-color:var(--gold);}
.task-label{font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.4rem;}
.task-card.required .task-label{color:var(--red);}
.task-card.annual .task-label{color:var(--gold);}
.task-card h4{font-family:'Playfair Display',serif;font-size:1.05rem;margin-bottom:0.4rem;}
.task-card p{font-size:0.85rem;color:var(--gray-mid);line-height:1.5;}
.task-status{margin-top:0.75rem;font-size:0.8rem;font-weight:600;}
.task-card.required .task-status{color:var(--red);}
.task-card.annual .task-status{color:var(--gold);}
.section-header{display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;}
.section-header h3{font-family:'Playfair Display',serif;font-size:1.4rem;color:var(--green-dark);}
.section-header .divider{flex:1;height:1px;background:var(--border);}
.handbook-progress{background:white;border-radius:10px;padding:1.25rem;margin-bottom:1.5rem;box-shadow:var(--shadow);display:flex;align-items:center;gap:1.25rem;}
.progress-bar-wrap{flex:1;}
.progress-label{font-size:0.8rem;font-weight:600;color:var(--green-dark);margin-bottom:0.4rem;}
.progress-bar{height:8px;background:var(--border);border-radius:4px;overflow:hidden;}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--green-mid),var(--green-light));border-radius:4px;transition:width 0.4s ease;}
.progress-count{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;color:var(--green-dark);white-space:nowrap;}
.handbook-chapter{background:white;border-radius:10px;margin-bottom:1rem;box-shadow:var(--shadow);overflow:hidden;}
.chapter-header{display:flex;align-items:center;padding:1rem 1.25rem;cursor:pointer;user-select:none;gap:0.75rem;transition:background 0.15s;}
.chapter-header:hover{background:var(--green-pale);}
.chapter-num{width:32px;height:32px;background:var(--green-pale);color:var(--green-dark);border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem;flex-shrink:0;}
.chapter-num.initialed{background:var(--green-dark);color:white;}
.chapter-title-wrap{flex:1;}
.chapter-title{font-weight:600;font-size:0.95rem;}
.chapter-type{font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-top:0.1rem;}
.chapter-type.initial{color:var(--red);}
.chapter-type.read-only{color:var(--blue-accent);}
.chapter-type.done{color:var(--green-mid);}
.chapter-arrow{color:var(--gray-mid);font-size:1.1rem;transition:transform 0.2s;}
.chapter-header.open .chapter-arrow{transform:rotate(180deg);}
.chapter-body{display:none;padding:0 1.25rem 1.25rem;border-top:1px solid var(--border);}
.chapter-body.open{display:block;}
.chapter-content{font-size:0.9rem;line-height:1.75;padding:1rem 0;}
.chapter-content h4{font-family:'Playfair Display',serif;color:var(--green-dark);margin:1rem 0 0.4rem;font-size:1rem;}
.chapter-content ul{padding-left:1.25rem;margin:0.5rem 0;}
.chapter-content li{margin-bottom:0.3rem;}
.chapter-content strong{color:var(--green-dark);}
.initial-block{background:#fff8e6;border:2px solid var(--gold);border-radius:8px;padding:1rem 1.25rem;margin-top:1rem;}
.initial-block p{font-size:0.875rem;margin-bottom:0.75rem;line-height:1.5;}
.initial-row{display:flex;gap:0.75rem;align-items:flex-end;flex-wrap:wrap;}
.initial-row input[type="text"]{padding:0.6rem 0.75rem;border:2px solid var(--border);border-radius:6px;font-size:0.9rem;width:80px;}
.btn-initial{padding:0.6rem 1.1rem;background:var(--gold);color:white;border:none;border-radius:6px;font-weight:600;font-size:0.875rem;cursor:pointer;}
.initial-done{display:none;align-items:center;gap:0.5rem;color:var(--green-mid);font-weight:600;font-size:0.875rem;}
.initial-done.show{display:flex;}
.sig-card{background:white;border-radius:10px;padding:1.5rem;margin-bottom:1.5rem;box-shadow:var(--shadow);border-top:4px solid var(--green-dark);}
.sig-card h4{font-family:'Playfair Display',serif;font-size:1.2rem;color:var(--green-dark);margin-bottom:0.5rem;}
.sig-card .description{font-size:0.9rem;color:var(--gray-mid);margin-bottom:1.25rem;line-height:1.6;}
.sig-card .doc-preview{background:var(--gray-light);border:1px solid var(--border);border-radius:6px;padding:1rem 1.25rem;margin-bottom:1.25rem;font-size:0.875rem;line-height:1.75;max-height:240px;overflow-y:auto;}
.sig-card .doc-preview h5{color:var(--green-dark);font-family:'Playfair Display',serif;margin-bottom:0.5rem;}
.sig-card .doc-preview ul{padding-left:1.25rem;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;}
.form-group{display:flex;flex-direction:column;gap:0.35rem;}
.form-group label{font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--green-dark);}
.form-group input{padding:0.65rem 0.85rem;border:2px solid var(--border);border-radius:7px;font-size:0.9rem;transition:border-color 0.2s;}
.form-group input:focus{outline:none;border-color:var(--green-mid);}
.sig-pad-wrap{margin:1rem 0;}
.sig-pad-wrap label{font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--green-dark);display:block;margin-bottom:0.4rem;}
.sig-pad{border:2px solid var(--border);border-radius:8px;cursor:crosshair;background:white;display:block;width:100%;max-width:500px;touch-action:none;}
.sig-controls{display:flex;gap:0.5rem;margin-top:0.5rem;}
.btn-clear{padding:0.4rem 0.85rem;background:transparent;border:1px solid var(--border);border-radius:5px;font-size:0.8rem;cursor:pointer;color:var(--gray-mid);}
.consent-check{display:flex;gap:0.75rem;align-items:flex-start;background:var(--green-pale);border-radius:8px;padding:1rem;margin:1rem 0;}
.consent-check input[type="checkbox"]{width:18px;height:18px;flex-shrink:0;margin-top:2px;accent-color:var(--green-dark);}
.consent-check label{font-size:0.875rem;line-height:1.55;}
.btn-submit{padding:0.85rem 2rem;background:var(--green-dark);color:white;border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:0.5rem;}
.success-msg{display:none;background:#eaf7ea;border:1px solid var(--green-light);border-radius:8px;padding:1rem 1.25rem;color:var(--green-dark);font-weight:600;align-items:center;gap:0.5rem;margin-top:1rem;}
.success-msg.show{display:flex;}
.annual-info{background:white;border-radius:10px;padding:1.25rem;margin-bottom:1.5rem;box-shadow:var(--shadow);border-left:4px solid var(--gold);}
.annual-info p{font-size:0.875rem;line-height:1.6;}
.annual-info strong{color:var(--gold);}
.complete-badge{display:none;background:linear-gradient(135deg,var(--green-mid),var(--green-light));color:white;border-radius:10px;padding:1.5rem;text-align:center;margin-bottom:1.5rem;}
.complete-badge.show{display:block;}
.complete-badge h3{font-family:'Playfair Display',serif;font-size:1.4rem;margin-bottom:0.4rem;}
.resource-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1rem;}
.resource-card{background:white;border-radius:10px;padding:1.25rem;box-shadow:var(--shadow);text-decoration:none;color:var(--text);border:1px solid var(--border);transition:transform 0.15s,box-shadow 0.15s;display:block;}
.resource-card:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(45,90,39,0.15);}
.resource-icon{font-size:2rem;margin-bottom:0.6rem;}
.resource-card h4{font-family:'Playfair Display',serif;font-size:1rem;margin-bottom:0.3rem;color:var(--green-dark);}
.resource-card p{font-size:0.82rem;color:var(--gray-mid);line-height:1.5;}

/* ── SCHEDULED JOBS ── */
.sj-job-card{background:white;border-radius:12px;padding:1.25rem 1.5rem;margin-bottom:1rem;box-shadow:var(--shadow);cursor:pointer;border:2px solid transparent;transition:all 0.2s;display:flex;align-items:center;gap:1rem;}
.sj-job-card:hover{border-color:var(--green-light);transform:translateY(-2px);}
.sj-flag{width:18px;height:18px;border-radius:3px;border:1px solid rgba(0,0,0,.15);flex-shrink:0;}
.sj-job-info{flex:1;}
.sj-job-name{font-family:'Playfair Display',serif;font-size:1.15rem;color:var(--green-dark);margin-bottom:0.2rem;}
.sj-job-meta{font-size:0.82rem;color:var(--gray-mid);}
.sj-pipeline{display:flex;gap:4px;margin-top:0.5rem;flex-wrap:wrap;}
.sj-pip-dot{width:10px;height:10px;border-radius:50%;border:2px solid var(--border);background:white;}
.sj-pip-dot.done{background:var(--green-mid);border-color:var(--green-mid);}
.sj-pip-dot.active{background:var(--gold);border-color:var(--gold);}
.sj-step-btn{flex:1;min-width:80px;padding:0.65rem 0.5rem;font-size:0.75rem;font-weight:600;border:none;border-right:1px solid var(--border);background:white;cursor:pointer;color:var(--gray-mid);transition:all 0.15s;white-space:nowrap;}
.sj-step-btn:last-child{border-right:none;}
.sj-step-btn:hover{background:var(--green-pale);color:var(--green-dark);}
.sj-step-btn.active{background:var(--green-dark);color:white;}
.sj-card{background:white;border-radius:10px;padding:1.25rem;margin-bottom:1rem;box-shadow:var(--shadow);}
.sj-card h4{font-family:'Playfair Display',serif;color:var(--green-dark);font-size:1.1rem;margin-bottom:0.75rem;}
.sj-section-label{font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--green-dark);margin-bottom:0.4rem;display:block;}
.sj-input{width:100%;padding:0.6rem 0.85rem;border:2px solid var(--border);border-radius:7px;font-size:0.9rem;margin-bottom:0.75rem;font-family:inherit;}
.sj-input:focus{outline:none;border-color:var(--green-mid);}
.sj-grid2{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:0.75rem;}
.sj-grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.75rem;margin-bottom:0.75rem;}
.sj-btn{padding:0.7rem 1.25rem;border:none;border-radius:8px;font-size:0.9rem;font-weight:600;cursor:pointer;font-family:inherit;transition:background 0.2s;}
.sj-btn-green{background:var(--green-dark);color:white;}.sj-btn-green:hover{background:var(--green-mid);}
.sj-btn-gold{background:var(--gold);color:white;}
.sj-btn-red{background:var(--red);color:white;}
.sj-btn-outline{background:transparent;color:var(--gray-mid);border:2px solid var(--border);}.sj-btn-outline:hover{border-color:var(--red);color:var(--red);}
.sj-alert-green{background:var(--green-pale);border:1px solid var(--green-light);border-radius:8px;padding:0.85rem 1rem;color:var(--green-dark);font-size:0.875rem;margin-bottom:1rem;}
.sj-alert-amber{background:#fff8e6;border:1px solid var(--gold);border-radius:8px;padding:0.85rem 1rem;color:#7a5c00;font-size:0.875rem;margin-bottom:1rem;}
.sj-alert-red{background:#fdeaea;border:1px solid var(--red);border-radius:8px;padding:0.85rem 1rem;color:var(--red);font-size:0.875rem;margin-bottom:1rem;}
.sj-truck-card{border:2px solid var(--border);border-radius:10px;padding:1rem;margin-bottom:0.85rem;}
.sj-truck-card.shipped{border-color:var(--green-mid);background:var(--green-pale);}
.sj-species-row{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:0.5rem;align-items:center;padding:0.5rem 0;border-bottom:1px solid var(--border);font-size:0.875rem;}
.sj-species-row:last-child{border-bottom:none;}
.sj-progress-bar{height:10px;background:var(--border);border-radius:5px;overflow:hidden;margin:0.4rem 0;}
.sj-progress-fill{height:100%;background:linear-gradient(90deg,var(--green-mid),var(--green-light));border-radius:5px;transition:width 0.4s;}
.needs-attention{background:#fff3e8;border:2px solid var(--orange-border);border-radius:6px;padding:0.5rem 0.85rem;color:var(--orange-dark);font-size:0.82rem;font-weight:700;display:inline-block;margin-top:0.3rem;}
@media(max-width:600px){.sj-grid2,.sj-grid3{grid-template-columns:1fr;}.sj-step-btn{font-size:0.65rem;padding:0.5rem 0.3rem;}.sj-species-row{grid-template-columns:1fr 1fr;}}

#panel-nursery{display:none;}
.nrs-header{background:var(--green);padding:0;display:flex;align-items:stretch;border-bottom:3px solid var(--green3);}
.nrs-hdr-left{padding:11px 16px;flex:1;}
.nrs-brand{font-family:'Bebas Neue',sans-serif;font-size:21px;color:#fff;letter-spacing:1px;line-height:1;}
.nrs-sub{font-family:'DM Mono',monospace;font-size:9px;color:rgba(255,255,255,.5);letter-spacing:1px;text-transform:uppercase;margin-top:2px;}
.nrs-hdr-right{padding:8px 14px;display:flex;flex-direction:column;align-items:flex-end;justify-content:center;gap:2px;}
.nrs-stat{font-family:'DM Mono',monospace;font-size:9px;color:rgba(255,255,255,.4);}
/* lock banner */
.lock-banner{background:#1a1a1a;color:#f0c040;padding:8px 16px;font-size:12px;font-family:'DM Mono',monospace;display:flex;align-items:center;justify-content:space-between;gap:8px;}
.lock-banner.unlocked{background:#1E4D0F;color:#a8e48a;}
.unlock-btn{background:#f0c040;color:#1a1a1a;border:none;border-radius:5px;padding:4px 12px;font-size:11px;font-weight:700;cursor:pointer;font-family:'DM Mono',monospace;}
.unlock-btn.lock-it{background:rgba(255,255,255,0.2);color:white;}
/* nursery bottom nav */
.bnav{position:sticky;bottom:0;left:0;right:0;background:var(--green);border-top:2px solid var(--green2);display:flex;z-index:100;}
.nb{flex:1;border:none;background:none;color:rgba(255,255,255,.5);padding:7px 2px 5px;display:flex;flex-direction:column;align-items:center;gap:1px;font-size:8px;font-family:'DM Mono',monospace;letter-spacing:.2px;text-transform:uppercase;cursor:pointer;transition:all .15s;position:relative;}
.nb.act{color:#fff;background:rgba(255,255,255,.1);}
.nb .ni{font-size:17px;line-height:1;}
.nbadge{position:absolute;top:3px;right:calc(50% - 16px);background:var(--red3);color:#fff;font-size:8px;font-weight:700;border-radius:100px;padding:1px 4px;display:none;}
.ncontent{max-width:960px;margin:0 auto;padding:14px 14px 80px;}
.nscreen{display:none;}.nscreen.active{display:block;animation:fadeIn .18s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}

/* nursery cards / UI */
.card{background:#fff;border:1px solid var(--brd2);border-radius:var(--r8);margin-bottom:12px;overflow:hidden;box-shadow:var(--shd);}
.ch2{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-bottom:1px solid var(--brd2);background:var(--paper);}
.chl{display:flex;align-items:center;gap:10px;flex:1;min-width:0;}
.cstep{font-family:'Bebas Neue',sans-serif;font-size:20px;color:var(--green3);line-height:1;width:24px;flex-shrink:0;}
.ctitle{font-size:14px;font-weight:600;}
.csub{font-size:11px;color:var(--ink3);margin-top:1px;}
.cb3{padding:13px;}
.stag{display:inline-flex;align-items:center;gap:6px;font-family:'DM Mono',monospace;font-size:10px;font-weight:500;letter-spacing:1.2px;text-transform:uppercase;color:var(--ink3);margin-bottom:10px;}
.stag::before{content:'';display:block;width:14px;height:2px;background:var(--green3);}
.fr{display:grid;gap:10px;margin-bottom:10px;}
.fc2{grid-template-columns:1fr 1fr;}.fc3{grid-template-columns:1fr 1fr 1fr;}
.nf{display:flex;flex-direction:column;gap:4px;}
.nf label{font-size:10px;font-weight:600;letter-spacing:.7px;text-transform:uppercase;font-family:'DM Mono',monospace;color:var(--ink3);}
.nf input,.nf select,.nf textarea{border:1px solid var(--brd);border-radius:var(--r4);padding:7px 10px;font-size:13px;background:var(--paper);color:var(--ink);}
.nf input:focus,.nf select:focus{outline:2px solid var(--green3);outline-offset:0;background:#fff;}
.nf textarea{resize:vertical;min-height:52px;}
.nbtn{display:inline-flex;align-items:center;gap:5px;font-size:13px;font-weight:500;padding:8px 14px;border-radius:var(--r6);border:1px solid;cursor:pointer;transition:all .12s;}
.nbg{background:var(--green2);color:#fff;border-color:var(--green);}.nbg:hover{background:var(--green3);}
.nbo{background:#fff;color:var(--ink);border-color:var(--brd);}.nbo:hover{background:var(--paper2);}
.nbr{background:var(--red2);color:#fff;border-color:var(--red);}
.nba{background:var(--amber2);color:#fff;border-color:var(--amber);}
.nbsm{font-size:11px;padding:5px 10px;}
.brow2{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;}
.nal{display:flex;gap:10px;padding:10px 12px;border-radius:var(--r6);font-size:13px;margin-bottom:10px;line-height:1.5;}
.nalg{background:var(--green-lt);border:1px solid var(--green3);color:var(--green);}
.nala{background:var(--amber-lt);border:1px solid var(--amber3);color:var(--amber);}
.nalr{background:var(--red-lt);border:1px solid var(--red3);color:var(--red);}
.nalb{background:var(--blue-lt);border:1px solid var(--blue3);color:var(--blue);}
.nali{font-size:16px;flex-shrink:0;margin-top:1px;}
.chip{display:inline-flex;align-items:center;font-family:'DM Mono',monospace;font-size:10px;padding:2px 7px;border-radius:100px;border:1px solid;white-space:nowrap;}
.cg{background:var(--green-lt);border-color:var(--green3);color:var(--green2);}
.cr{background:var(--red-lt);border-color:var(--red3);color:var(--red2);}
.ca{background:var(--amber-lt);border-color:var(--amber3);color:var(--amber2);}
.cb2{background:var(--blue-lt);border-color:var(--blue3);color:var(--blue2);}
.cgo{background:var(--gold-lt);border-color:var(--gold2);color:var(--gld);}
.ndiv{height:1px;background:var(--brd2);margin:12px 0;}
.tbl{width:100%;border-collapse:collapse;font-size:12px;}
.tbl th{background:var(--paper);padding:7px 10px;text-align:left;font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.6px;text-transform:uppercase;color:var(--ink3);border-bottom:1px solid var(--brd);}
.tbl td{padding:7px 10px;border-bottom:1px solid var(--brd2);vertical-align:middle;}
.tbl tr:last-child td{border-bottom:none;}
.tbl tr:hover td{background:var(--paper);}
.mbg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:300;align-items:flex-start;justify-content:center;padding:16px;overflow-y:auto;}
.mbg.open{display:flex;}
.modal{background:#fff;border-radius:var(--r12);width:100%;max-width:620px;margin:auto;box-shadow:0 8px 32px rgba(0,0,0,.2);}
.mh{display:flex;align-items:center;justify-content:space-between;padding:13px 16px;border-bottom:1px solid var(--brd2);background:var(--paper);}
.mt2{font-weight:600;font-size:15px;}
.mc{font-size:22px;color:var(--ink3);border:none;background:none;cursor:pointer;}
.mb{padding:16px;}
.sg{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px;}
.sb{background:var(--paper);border:1px solid var(--brd2);border-radius:var(--r8);padding:12px;text-align:center;}
.sn{font-family:'Bebas Neue',sans-serif;font-size:30px;line-height:1;}
.sl{font-family:'DM Mono',monospace;font-size:9px;color:var(--ink3);text-transform:uppercase;letter-spacing:.5px;margin-top:2px;}
.search-wrap{position:relative;margin-bottom:10px;}
.search-wrap input{width:100%;padding:9px 12px 9px 36px;border:1px solid var(--brd);border-radius:var(--r6);font-size:13px;background:var(--paper);}
.search-wrap::before{content:'🔍';position:absolute;left:10px;top:50%;transform:translateY(-50%);font-size:14px;pointer-events:none;}
.ntoast{position:fixed;bottom:72px;left:50%;transform:translateX(-50%) translateY(16px);background:var(--ink);color:#fff;padding:8px 16px;border-radius:100px;font-size:12px;font-family:'DM Mono',monospace;opacity:0;transition:all .3s;z-index:600;white-space:nowrap;pointer-events:none;}
.ntoast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.loc-pill{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-family:'DM Mono',monospace;padding:2px 8px;border-radius:100px;border:1px solid;}
.loc-office{background:#EBF5DE;border-color:#4A9425;color:#1E4D0F;}
.loc-pump{background:#E5EEFB;border-color:#3D7FD4;color:#0A3260;}
.loc-bt{background:#FDF8E1;border-color:#C49A1E;color:#8B6914;}
.loc-vendor{background:#F7F4EC;border-color:#9A9884;color:#3A3929;}
.scan-preview{border:2px dashed var(--brd);border-radius:var(--r8);padding:20px;text-align:center;background:var(--paper2);cursor:pointer;transition:all .15s;}
.scan-preview:hover{border-color:var(--green3);background:var(--green-lt);}
.scan-preview img{max-width:100%;border-radius:var(--r4);margin-bottom:10px;}
.harden-row{display:flex;align-items:center;gap:8px;padding:8px 12px;border-bottom:1px solid var(--brd2);font-size:12px;}
.flag-or{background:var(--amber-lt);border:2px solid var(--amber3);border-radius:var(--r8);padding:14px;margin-bottom:12px;}
.pb{height:8px;background:var(--brd2);border-radius:4px;overflow:hidden;}
.pbf{height:100%;border-radius:4px;transition:width 0.4s;}

/* view-only overlay — disables all nursery edit controls */
.view-only-mode button:not(.nb):not(.btn-back):not(.omw-closer):not(.nrs-back-btn):not(.unlock-btn),
.view-only-mode input:not([type="radio"]):not([type="checkbox"]),
.view-only-mode select,
.view-only-mode textarea,
.view-only-mode .scan-preview{
  opacity:0.45;pointer-events:none;cursor:not-allowed;
}
.view-only-mode .nb{opacity:1;pointer-events:auto;cursor:pointer;}

@media(max-width:580px){.fc3{grid-template-columns:1fr 1fr;}.sg{grid-template-columns:repeat(3,1fr);}}
@media(max-width:600px){.form-row,.reorder-detail-row{grid-template-columns:1fr;}.tasks-grid,.tiles-grid{grid-template-columns:1fr;}.portal-header h2{display:none;}}
