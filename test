function previewMntPhoto(e){
  const file=e.target.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=ev=>{document.getElementById('mnt-photo-preview').innerHTML=`<img src="${ev.target.result}" style="width:100%;max-height:120px;object-fit:cover;border-radius:5px;margin-top:6px;">`; window._mntPhotoData=ev.target.result;};
  reader.readAsDataURL(file);
