// ── Helper: show/hide custom input when "Other/Custom" is selected ──
function odToggleCustom(sel, customId){
  var el=document.getElementById(customId); if(!el) return;
  el.style.display=(sel.value.indexOf('Other')===0||sel.value.indexOf('Custom')===0)?'block':'none';
}

