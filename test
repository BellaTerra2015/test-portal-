function sendFormspree(data,successId){
  fetch(FORMSPREE,{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify(data)}).then(()=>document.getElementById(successId).classList.add('show')).catch(()=>alert('Error sending. Check your connection.'));
}
function initCanvases(){['canvas-410','canvas-breaks'].forEach(initCanvas);}
function initCanvas(id){
  var canvas=document.getElementById(id);if(!canvas||canvas.dataset.init)return;canvas.dataset.init='1';
  var ctx=canvas.getContext('2d');var drawing=false,lastX=0,lastY=0;
  ctx.strokeStyle='#1a1a1a';ctx.lineWidth=2;ctx.lineCap='round';ctx.lineJoin='round';
  function pos(e){var r=canvas.getBoundingClientRect(),sx=canvas.width/r.width,sy=canvas.height/r.height;if(e.touches)return{x:(e.touches[0].clientX-r.left)*sx,y:(e.touches[0].clientY-r.top)*sy};return{x:(e.clientX-r.left)*sx,y:(e.clientY-r.top)*sy};}
  canvas.addEventListener('mousedown',e=>{drawing=true;var p=pos(e);lastX=p.x;lastY=p.y;});
  canvas.addEventListener('mousemove',e=>{if(!drawing)return;var p=pos(e);ctx.beginPath();ctx.moveTo(lastX,lastY);ctx.lineTo(p.x,p.y);ctx.stroke();lastX=p.x;lastY=p.y;});
  canvas.addEventListener('mouseup',()=>drawing=false);canvas.addEventListener('mouseleave',()=>drawing=false);
  canvas.addEventListener('touchstart',e=>{e.preventDefault();drawing=true;var p=pos(e);lastX=p.x;lastY=p.y;},{passive:false});
  canvas.addEventListener('touchmove',e=>{e.preventDefault();if(!drawing)return;var p=pos(e);ctx.beginPath();ctx.moveTo(lastX,lastY);ctx.lineTo(p.x,p.y);ctx.stroke();lastX=p.x;lastY=p.y;},{passive:false});
  canvas.addEventListener('touchend',()=>drawing=false);
}
function clearSig(id){var c=document.getElementById(id);c.getContext('2d').clearRect(0,0,c.width,c.height);}
function hasSignature(canvas){var d=canvas.getContext('2d').getImageData(0,0,canvas.width,canvas.height).data;for(var i=3;i<d.length;i+=4){if(d[i]>0)return true;}return false;}

