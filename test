const FERT_RATE={'plug':'½ tsp','4in':'½ tsp','bare root':'N/A','#1':'1 tsp','#2':'2 tsp','#3':'1 tbsp','#5':'1 tbsp'};
function buildCare(){buildFert();buildHarden();}
function buildFert(){
  const mi=parseInt(document.getElementById('fert-mo')?.value||3);
  let html=`<table class="tbl" style="min-width:540px"><thead><tr><th>Species</th><th>Water · Sun</th><th>Container</th><th>Rate</th><th>Root Check</th><th>Applied</th></tr></thead><tbody>`;
  masterSpecies.forEach(s=>{
    const qty=invTotal(s.id);if(!qty)return;
    const entries=stock.filter(e=>e.spId===s.id);const cont=entries[0]?.container||'#1';
    const rk=s.id+'_'+mi,r=fertRes[rk],done=fertDone[rk],flagged=redFlags[s.id];
