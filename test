function toggleJobSelection(index) {
  const checked = document.getElementById(`job-check-${index}`).checked;
  const card = document.getElementById(`job-card-${index}`);
  card.style.opacity = checked ? '1' : '0.4';
  card.style.borderColor = checked ? 'var(--border)' : '#ccc';
  updateSendButton();
}

function toggleAllJobs() {
  const allChecked = schedulerJobs.every((_, i) =>
    document.getElementById(`job-check-${i}`)?.checked);
  schedulerJobs.forEach((_, i) => {
    const cb = document.getElementById(`job-check-${i}`);
    if (cb) { cb.checked = !allChecked; toggleJobSelection(i); }
  });
  document.getElementById('select-all-btn').textContent = allChecked ? 'Check All' : 'Uncheck All';
}

function updateSendButton() {
  const count = schedulerJobs.filter((_, i) =>
    document.getElementById(`job-check-${i}`)?.checked).length;
  const btn = document.getElementById('send-btn');
  if (btn) {
    btn.textContent = `📤 Send Confirmations (${count})`;
    btn.disabled = count === 0;
    btn.style.background = count === 0 ? '#aaa' : 'var(--green-dark)';
  }
}

function updateJobTime(index, type, value) {
  if (type === 'start') {
    schedulerJobs[index].startTime = value;
  } else {
    schedulerJobs[index].endTime = value;
  }
}

function previewMessage(index) {
  const job = schedulerJobs[index];
  const preview = document.getElementById(`preview-${index}`);
  
  const message = buildConfirmationMessage(job);
  preview.textContent = message;
  preview.style.display = 'block';
}

function buildConfirmationMessage(job) {
  const start = formatTime(job.startTime);
  const end = formatTime(job.endTime);
  const date = job.date; // Already formatted as "April 8th"
  
  let serviceText;
  if (job.services.length === 1) {
    serviceText = `SERVICE: ${job.services[0]}`;
  } else {
    serviceText = `SERVICES:\n${job.services.map(s => `• ${s}`).join('\n')}`;
  }
  
  return `Good news! ☀️ Bella Terra scheduled for tomorrow, ${date} between ${start} - ${end}.

${serviceText}

ADDRESS: ${job.address}

Reply Y to confirm, D to delay or update, C to cancel.

Questions? Call 360-225-1125`;
}

function formatTime(time24) {
  const [hours, minutes] = time24.split(':');
  const h = parseInt(hours);
  const ampm = h >= 12 ? 'PM' : 'AM';
  const h12 = h === 0 ? 12 : h > 12 ? h - 12 : h;
  return `${h12}:${minutes} ${ampm}`;
}

async function sendAllConfirmations() {
  const selectedJobs = schedulerJobs.filter((_, i) =>
    document.getElementById(`job-check-${i}`)?.checked);

  if (selectedJobs.length === 0) {
    alert('No customers selected. Check at least one box to send.');
    return;
  }

  if (!confirm(`Send confirmation texts to ${selectedJobs.length} customer(s)?`)) {
    return;
  }

  const button = document.getElementById('send-btn');
  button.disabled = true;
  button.textContent = 'Sending...';

  try {
    const response = await fetch(APPS_SCRIPT_SCHEDULER_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain;charset=utf-8' },
      body: JSON.stringify({
        action: 'sendConfirmations',
        jobs: selectedJobs
      })
    });
    
    const result = await response.json();
    
    if (result.success) {
      alert(`✅ Successfully sent ${result.sent} confirmation text(s)!`);
      closeServiceScheduler();
    } else {
      throw new Error(result.error || 'Unknown error');
    }
    
  } catch (error) {
    alert(`❌ Error sending texts: ${error.message}`);
    button.disabled = false;
    updateSendButton();
  }
}

