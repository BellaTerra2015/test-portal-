var nurseryEditMode = false;

function promptUnlock(){
  const modal=document.getElementById('m-unlock');
  if(!modal){alert('Unlock modal not found.');return;}
  document.getElementById('unlock-pass').value='';
  document.getElementById('unlock-error').style.display='none';
  // Force modal visible regardless of parent panel state
  modal.style.display='flex';
  modal.classList.add('open');
  setTimeout(()=>{const p=document.getElementById('unlock-pass');if(p)p.focus();},200);
}

function closeUnlockModal(){
  const modal=document.getElementById('m-unlock');
  if(modal){modal.classList.remove('open');modal.style.display='';}
}

function tryUnlock(){
  const pw=document.getElementById('unlock-pass').value;
  if(pw===NURSERY_EDIT_PW){
    nurseryEditMode=true;
    closeUnlockModal();
    applyEditMode();
    nToast('✅ Edit mode unlocked');
  } else {
    document.getElementById('unlock-error').style.display='block';
  }
}

function applyEditMode(){
  var panel = document.getElementById('panel-nursery');
  var banner = document.getElementById('lock-banner');
  if(nurseryEditMode){
    panel.classList.remove('view-only-mode');
    banner.classList.add('unlocked');
    banner.innerHTML='<span>✅ Edit mode — changes will be saved</span><button class="unlock-btn lock-it" onclick="lockNursery()">🔒 Lock</button>';
  } else {
    panel.classList.add('view-only-mode');
    banner.classList.remove('unlocked');
    banner.innerHTML='<span>🔒 View-only mode — tap Unlock to make changes</span><button class="unlock-btn" onclick="promptUnlock()">🔓 Unlock to Edit</button>';
  }
}

function lockNursery(){
  nurseryEditMode = false;
  applyEditMode();
  nToast('🔒 Edit mode locked');
}

