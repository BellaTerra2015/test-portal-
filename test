  sendFormspree({_subject:'Bella Terra '+(type==='410'?'4/10 Agreement':'Break & Meal Acknowledgment')+' — '+name,employee_name:name,position:document.getElementById(type+'-position').value||'',date_of_hire:document.getElementById(type+'-hire').value||'',signature_date:date,form_type:type==='410'?'4/10 Work Schedule Agreement':'Break & Meal Period Acknowledgment',signature_image:canvas.toDataURL('image/png'),consent_confirmed:'Yes',_replyto:'payroll@1BellaTerra.com'},'success-'+type);
