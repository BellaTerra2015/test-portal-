function savePotUp(orderId,spId){
  const order=pottingQueue.find(o=>o.id===orderId);if(!order)return;
  const item=(order.items||[]).find(i=>i.spId===spId);if(!item)return;
  const qty=parseInt(document.getElementById('pu-qty').value)||0;if(qty<=0){nToast('Enter qty > 0');return;}
  const cont=document.getElementById('pu-cont').value;const loc=document.getElementById('pu-loc').value;const notes=document.getElementById('pu-notes').value;
  const sp=spById(spId);

  // 1 — Add potted plants to inventory as new container size
  stock.push({id:'stk_'+Date.now(),spId,container:cont,qty,location:loc,origin:'bare_root_purchase',dateAdded:nToday(),notes:`Potted from ${order.vendor} Invoice ${order.invoiceNum}. ${notes}`,jobAlloc:order.jobAlloc});

  // 2 — Subtract potted qty from matching bare root / plug inventory entries
  //     Work through entries oldest-first, deducting until qty is consumed
  const sourceContainers=['bare root','plug','4in','live stake'];
  let remaining=qty;
  const sourceEntries=stock
    .filter(e=>e.spId===spId && sourceContainers.includes(e.container) && (parseInt(e.qty)||0)>0)
    .sort((a,b)=>(a.dateAdded||'').localeCompare(b.dateAdded||'')); // oldest first

  for(const entry of sourceEntries){
    if(remaining<=0)break;
    const available=parseInt(entry.qty)||0;
    const deduct=Math.min(available,remaining);
    entry.qty=available-deduct;
    remaining-=deduct;
  }
  // Remove any entries that hit zero
  stock=stock.filter(e=>(parseInt(e.qty)||0)>0);
  sv(SK.stock,stock);

  // 3 — Update potting queue progress
  item.qtyPotted=(parseInt(item.qtyPotted)||0)+qty;
  const allDone=(order.items||[]).every(i=>(parseInt(i.qtyPotted)||0)>=(parseInt(i.qtyReceived)||0));
  const anyDone=(order.items||[]).some(i=>(parseInt(i.qtyPotted)||0)>0);
  order.status=allDone?'complete':anyDone?'in_progress':'heeled';svPQ();

  closeM('m-potup');
  const leftInQueue=(parseInt(item.qtyReceived)||0)-(parseInt(item.qtyPotted)||0);
  nToast(`✅ ${qty} ${sp.common} potted → ${LOC_LABELS[loc]}${leftInQueue>0?' · '+leftInQueue+' left to pot':' · queue complete'}`);
  buildPottingQueue();buildInv();buildDash();
}

function closeOrder(orderId){const o=pottingQueue.find(x=>x.id===orderId);if(o){o.status='complete';svPQ();buildPottingQueue();nToast('✅ Order complete');}}

