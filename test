function saveMaintenanceLog(){
  const date=document.getElementById('mnt-date').value;if(!date){alert('Enter a date.');return;}
  const tasks=[...document.querySelectorAll('.mnt-task-chk:checked')].map(c=>c.value);
  const flags=[];
  for(let i=1;i<=mntFlagCount;i++){
    const sec=document.getElementById('mnt-flag-sec-'+i);const st=document.getElementById('mnt-flag-status-'+i);
    if(sec&&st&&sec.value)flags.push({section:sec.value,status:st.value,note:st.value==='attention'?'Flagged for next crew':'Checked OK'});
  }
  const log={id:'mnt_'+Date.now(),date,crew:document.getElementById('mnt-crew').value,hours:document.getElementById('mnt-hours').value,tasks,flags,photo:window._mntPhotoData||null};
  if(!currentSJJob.maintenanceLogs) currentSJJob.maintenanceLogs=[];
  currentSJJob.maintenanceLogs.push(log);
  saveSJJob();window._mntPhotoData=null;mntFlagCount=0;
  document.getElementById('m-maintenance').classList.remove('open');
  renderSJStep('maintenance',document.getElementById('sj-step-maintenance'));
}

