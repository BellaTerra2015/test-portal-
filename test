function spById(id){return masterSpecies.find(s=>s.id===id)||{common:'Unknown',sci:'',type:'shrub',sizes:['#1'],id};}
function invTotal(spId,cont){return stock.filter(e=>e.spId===spId&&(!cont||e.container===cont)).reduce((s,e)=>s+(parseInt(e.qty)||0),0);}
function invBySize(spId){const m={};stock.filter(e=>e.spId===spId).forEach(e=>{m[e.container]=(m[e.container]||0)+(parseInt(e.qty)||0)});return m;}

const LOC_LABELS={office:'Office Nursery',pump:'Pump House',bt:'BT Landholdings',vendor:'Vendor'};
const LOC_CLASS={office:'loc-office',pump:'loc-pump',bt:'loc-bt',vendor:'loc-vendor'};
const SIZE_ORDER=['plug','4in','bare root','live stake','#1','#2','#3','#5','#7'];
function sizeRank(s){return SIZE_ORDER.indexOf(s);}
function isSmaller(a,b){return sizeRank(a)<sizeRank(b)&&sizeRank(a)>=0;}

function waterIcons(n){const drop='💧';return n?`<span title="Water">${drop.repeat(n)}</span>`:''}
function sunIcon(s){const map={shade:'🌑',part:'🌓',full:'☀️'};return s?`<span>${map[s]||'—'}</span>`:''}
function waterSunBadge(sp){if(!sp)return'';const w=sp.water?waterIcons(sp.water):'';const s=sp.sun?sunIcon(sp.sun):'';return(w||s)?`<span style="font-size:13px;white-space:nowrap">${w}${s?'&nbsp;'+s:''}</span>`:''}

