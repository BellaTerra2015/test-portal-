    <div class="sb"><div class="sn" style="color:var(--green3)">${total.toLocaleString()}</div><div class="sl">Total Stock</div></div>
    <div class="sb"><div class="sn" style="color:var(--blue2)">${activeJobs}</div><div class="sl">Active Jobs</div></div>
    <div class="sb"><div class="sn" style="color:var(--ink3)">${pottingQueue.filter(o=>o.status!=='complete').length}</div><div class="sl">To Pot</div></div>`;
