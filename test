}

function getPruneFlag(spId,jobId){const checkJobs=jobId?[jobs.find(j=>j.id===jobId)].filter(Boolean):jobs;for(const j of checkJobs){const t=(j.targets||[]).find(t=>t.spId===spId);if(t&&t.stemForm&&(t.stemForm.toLowerCase().includes('multi')||t.stemForm.toLowerCase().includes('cane')))return{flag:true,job:j.name,spec:t.stemForm};}return{flag:false};}
function getCaliperFlag(spId,jobId){const checkJobs=jobId?[jobs.find(j=>j.id===jobId)].filter(Boolean):jobs;for(const j of checkJobs){const t=(j.targets||[]).find(t=>t.spId===spId);if(t&&t.caliperSpec&&t.caliperSpec!=='—'&&t.caliperSpec!=='')return{flag:true,job:j.name,spec:t.caliperSpec};}return{flag:false};}

function confirmInvoiceResults(){
  if(!nurseryEditMode){nToast('🔒 Unlock edit mode first');return;}
  const vendor=document.getElementById('inv-vendor').value||'Unknown Vendor';
  const invNum=document.getElementById('inv-invnum').value||'—';
  const invDate=document.getElementById('inv-invdate').value||nToday();
  const jobId=document.getElementById('inv-job').value;
