// ── Navigation ──
function showJobs(){
  ['main-tiles','panel-scheduledjobs','panel-resources','panel-nursery','panel-olydisco']
    .forEach(id=>{ var el=document.getElementById(id); if(el) el.style.display='none'; });
  document.getElementById('panel-jobs').style.display='block';
  renderJobsList();
  updateJobsBadge();
}

function showOlyDisco(){
  document.getElementById('panel-jobs').style.display='none';
  document.getElementById('panel-olydisco').style.display='block';
  odAutoFill();
  showOdPanel('od-bark', document.getElementById('od-tab-bark'));
}

function renderJobsList(){
  var el = document.getElementById('jobs-list');
  if(!el) return;
  el.innerHTML = JOBS.map(function(j){
    if(completedJobs[j.id]) return '';
    if(!j.active){
      return '<div style="background:white;border-radius:12px;padding:1.25rem 1.5rem;margin-bottom:0.85rem;opacity:0.45;display:flex;align-items:center;gap:1rem;border:2px solid var(--border);">'
        +'<span style="font-size:1.8rem;">'+j.icon+'</span>'
        +'<div style="flex:1;"><div style="font-family:\'Playfair Display\',serif;font-size:1.05rem;color:var(--green-dark);">'+j.name+'</div>'
        +'<div style="font-size:0.82rem;color:var(--gray-mid);">'+j.desc+'</div></div>'
        +'<span style="font-size:0.72rem;background:#e0e0e0;color:#888;padding:0.25rem 0.75rem;border-radius:20px;font-weight:700;white-space:nowrap;">COMING SOON</span></div>';
    }
    return '<div onclick="showOlyDisco()" style="background:white;border-radius:12px;padding:1.25rem 1.5rem;margin-bottom:0.85rem;cursor:pointer;display:flex;align-items:center;gap:1rem;border:2px solid var(--border);box-shadow:var(--shadow);transition:all 0.2s;" onmouseover="this.style.borderColor=\'var(--green-mid)\'" onmouseout="this.style.borderColor=\'var(--border)\'">'
      +'<span style="font-size:1.8rem;">'+j.icon+'</span>'
      +'<div style="flex:1;"><div style="font-family:\'Playfair Display\',serif;font-size:1.05rem;color:var(--green-dark);margin-bottom:0.2rem;">'+j.name+'</div>'
      +'<div style="font-size:0.82rem;color:var(--gray-mid);">'+j.desc+'</div></div>'
      +'<span style="font-size:0.72rem;background:#2d5a27;color:white;padding:0.25rem 0.75rem;border-radius:20px;font-weight:700;white-space:nowrap;">● ACTIVE</span>'
      +'<span style="color:var(--gray-mid);font-size:1.2rem;">›</span></div>';
  }).join('');
