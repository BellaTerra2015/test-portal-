        <div style="flex:1"><div style="font-weight:600">${j.name}</div><div style="font-size:11px;color:var(--ink3)">${j.location||''} ${j.outplantDate?'· '+j.outplantDate:''} ${j.state==='OR'?'<span class="chip ca">OR ⚠️</span>':''}</div></div>
        <span style="color:var(--ink4);font-size:18px">›</span>
