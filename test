function ld(k){try{return JSON.parse(localStorage.getItem(k)||'null')}catch{return null}}
function sv(k,v){try{localStorage.setItem(k,JSON.stringify(v))}catch{}}
function nToday(){return new Date().toISOString().split('T')[0];}

let masterSpecies=(()=>{const saved=ld(SK.plants)||[];const ids=new Set(DEFAULT_SPECIES.map(s=>s.id));const custom=saved.filter(s=>!ids.has(s.id)&&s.custom);return[...DEFAULT_SPECIES,...custom];})();
