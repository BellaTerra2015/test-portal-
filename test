function saveDailyReport(targetCount){
  const j=currentSJJob;
  const date=document.getElementById('dr-date').value;
  if(!date){alert('Enter a date.');return;}
  const species=[];
  const targets=j.targets||[];
  for(let i=0;i<targetCount;i++){const qty=parseInt(document.getElementById('dr-sp-'+i)?.value)||0;if(qty>0)species.push({spId:targets[i].spId,qty});}
  if(!species.length){alert('Enter at least one species qty.');return;}
  const report={id:'dr_'+Date.now(),date,stationFrom:document.getElementById('dr-sta-from').value,stationTo:document.getElementById('dr-sta-to').value,crew:document.getElementById('dr-crew').value,hours:document.getElementById('dr-hours').value,weather:document.getElementById('dr-weather').value,inspector:document.getElementById('dr-inspector').value,notes:document.getElementById('dr-notes').value,species};
  if(!j.dailyReports) j.dailyReports=[];
  j.dailyReports.push(report);
  saveSJJob();
  document.getElementById('m-dailyreport').classList.remove('open');
  emailDailyReport(j.dailyReports.length-1);
  renderSJStep('planting',document.getElementById('sj-step-planting'));
}

function emailDailyReport(idx){
  const j=currentSJJob;const r=j.dailyReports[idx];if(!r)return;
  const targets=j.targets||[];
  const totalContract=targets.reduce((s,t)=>s+(parseInt(t.qty)||0),0);
  const totalPlanted=j.dailyReports.reduce((s,rr)=>s+(rr.species||[]).reduce((ss,sp)=>ss+(parseInt(sp.qty)||0),0),0);
  const dayTotal=(r.species||[]).reduce((s,sp)=>s+(parseInt(sp.qty)||0),0);
  const spLines=(r.species||[]).map(sp=>`  - ${spById(sp.spId).common||sp.spId}: ${sp.qty}`).join('\n');
  const subject=encodeURIComponent(`Daily Planting Report — ${j.name} — ${r.date}`);
  const body=encodeURIComponent(`DAILY PLANTING REPORT\n${'='.repeat(40)}\nJob: ${j.name}\nContract: ${j.contractNum||'—'}\nDate: ${r.date}\nStations: ${r.stationFrom||'?'} to ${r.stationTo||'?'}\nCrew: ${r.crew||'?'} people · ${r.hours||'?'} hours\nWeather: ${r.weather||'—'}\nInspector: ${r.inspector||'—'}\n\nSPECIES PLANTED TODAY:\n${spLines}\n\nDAY TOTAL: ${dayTotal.toLocaleString()} plants\n\nCONTRACT PROGRESS:\nPlanted to date: ${totalPlanted.toLocaleString()} / ${totalContract.toLocaleString()} (${totalContract?Math.round(totalPlanted/totalContract*100):0}% complete)\n\nNotes:\n${r.notes||'None'}\n\n-- Sent from Bella Terra Field Ops App`);
  window.location.href=`mailto:Rena@1BellaTerra.com?subject=${subject}&body=${body}`;
}

