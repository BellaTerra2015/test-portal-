}

function markTruckShipped(ti){
  if(!confirm('Mark this truck as shipped? This will deduct these plants from nursery inventory.')) return;
  const tk = currentSJJob.trucks[ti];
  tk.shipped = true;
  tk.shippedDate = new Date().toISOString().split('T')[0];

  // Deduct from nursery inventory
  (tk.items||[]).forEach(item=>{
    if(item.source!=='nursery') return;
    let remaining = parseInt(item.qty)||0;
    const entries = stock.filter(e=>e.spId===item.spId&&e.container===item.container&&(parseInt(e.qty)||0)>0).sort((a,b)=>(a.dateAdded||'').localeCompare(b.dateAdded||''));
    for(const e of entries){
      if(remaining<=0) break;
      const avail = parseInt(e.qty)||0;
      const deduct = Math.min(avail,remaining);
      e.qty = avail-deduct;
      remaining -= deduct;
    }
  });
  stock = stock.filter(e=>(parseInt(e.qty)||0)>0);
  sv(SK.stock,stock);

  // Advance job status
  currentSJJob.status = 'shipping';
  saveSJJob();
  renderSJStep('pullsheet',document.getElementById('sj-step-pullsheet'));
  buildDash();
}

