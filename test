    if(!spId||!qty)return;
    const pruneF=getPruneFlag(spId,jobId);const calF=getCaliperFlag(spId,jobId);
    const targetCont=calF.flag?'check':cont;
    items.push({spId,qtyReceived:qty,qtyPotted:0,targetContainer:targetCont,pruneFlag:pruneF.flag?pruneF:null,caliperFlag:calF.flag?calF:null,notes:''});
