<body>

<!-- ═══ LOGIN ═══ -->
<div id="login-screen">
  <h1>🌿 Bella Terra</h1>
  <p>Employee Portal · Woodland, WA</p>
  <div class="login-box">
    <div class="form-group" style="margin-bottom:0">
      <label>Employee Name</label>
      <input type="text" id="login-name" placeholder="First Last" autocomplete="name">
    </div>
    <div class="form-group" style="margin:1rem 0 0">
      <label>Portal Password</label>
      <input type="password" id="login-pass" placeholder="Enter password">
    </div>
    <p class="error-msg" id="login-error">Incorrect password. Please try again.</p>
    <button class="btn-primary" style="margin-top:1.25rem" onclick="doLogin()">Access Portal</button>
  </div>
</div>

<!-- ═══ PORTAL ═══ -->
<div id="portal">
  <div class="portal-header">
    <h2>🌿 Bella Terra LLC</h2>
    <div class="header-right">
      <span class="employee-badge" id="employee-badge">👤 Employee</span>
      <button class="btn-logout" onclick="doLogout()">Sign Out</button>
    </div>
  </div>

  <!-- CLACKAMAS MONTHLY REMINDER BANNER -->
  <div id="clackamas-reminder-banner" style="display:none;background:#fdeaea;border-bottom:2px solid #c0392b;padding:0.85rem 1.5rem;display:none;align-items:center;justify-content:space-between;gap:1rem;">
    <div style="font-size:0.95rem;color:#c0392b;font-weight:600;">📸 Reminder: It's the 1st — submit Clackamas Water hydrant photos to the office today.</div>
    <button onclick="document.getElementById('clackamas-reminder-banner').style.display='none';" style="background:transparent;border:none;font-size:1.25rem;cursor:pointer;color:#c0392b;flex-shrink:0;">&times;</button>
  </div>

  <!-- MAIN TILES -->
  <div id="main-tiles">
    <div class="portal-main">
      <div class="portal-welcome">
        <h3>Welcome, <span id="welcome-name">Employee</span> 👋</h3>
        <p>Select a section below to get started.</p>
      </div>
      <div class="tiles-grid">
        <!-- NURSERY tile — now opens internal nursery panel -->
        <div class="tile" onclick="showNursery()">
          <div class="tile-icon">🌱</div>
          <h3>Nursery</h3>
          <p>Plant inventory, potting queue, jobs, and growing resources.</p>
        </div>
        <div class="tile" onclick="showHydroMenu()">
          <div class="tile-icon">💧</div>
          <h3>Hydroseeding</h3>
          <p>Platform operations, safety policies, and equipment guidelines.</p>
        </div>
        <div class="tile" onclick="showBarkMenu()">
          <div class="tile-icon">🌬️</div>
          <h3>Bark Blowing</h3>
          <p>Bark blowing operations, safety policies, and equipment guidelines.</p>
        </div>
        <div class="tile" onclick="window.location.href='scheduled_projects.html'">
          <div class="tile-icon">📋</div>
          <h3>Project Board</h3>
          <p>Awarded jobs, stages, safety plans, scope reports, and maintenance tracking.</p>
        </div>
        <a class="tile" href="fleet_vehicles.html">
          <div class="tile-icon">🚛</div>
          <h3>Fleet Management</h3>
          <p>Repair requests, maintenance log, inspections, accident reporting, and vehicle cards.</p>
        </a>
        <div class="tile has-badge" onclick="showResources()">
          <span class="tile-badge" id="res-badge">!</span>
          <div class="tile-icon">👥</div>
          <h3>Employee Resources</h3>
          <p>Handbook, required signatures, contacts, and HR documents.</p>
        </div>
        <div class="tile" onclick="openServiceScheduler()">
          <div class="tile-icon">📋</div>
          <h3>Service Scheduler</h3>
          <p>Send day-before confirmation texts to tomorrow's customers.</p>
        </div>
        <div class="tile" onclick="window.location.href='log_a_call.html'">
          <div class="tile-icon">📞</div>
          <h3>Log a Call</h3>
          <p>Record incoming customer calls for hydroseeding and bark blowing inquiries.</p>
        </div>
      </div>
    </div>
  </div>

