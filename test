    var idx=row.id.replace('plant-row-','');
    var sp=document.getElementById('plant-sp-'+idx); if(!sp) return;
    rows.push({species:sp.value.indexOf('Other')===0?odV('plant-sp-custom-'+idx):sp.value,
      qty:odV('plant-qty-'+idx),size:odV('plant-size-'+idx),source:odV('plant-src-'+idx),
      plan_section:odV('plant-sec-'+idx)||odV('plant-sec-custom-'+idx),
      field_change:odV('plant-chg-'+idx)});
  });
  return rows;
}

