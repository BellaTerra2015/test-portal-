    crew_lead:odV('complete-lead'),completion_date:odV('complete-date'),
    final_notes:odV('complete-notes')};
  fetch(APPS_SCRIPT,{method:'POST',mode:'no-cors',headers:{'Content-Type':'text/plain'},body:JSON.stringify(payload)})
    .then(function(){ odJobCompleteDone(); })
    .catch(function(){ odJobCompleteDone(); });
