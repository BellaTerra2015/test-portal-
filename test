function updateJobsBadge(){
  var count = JOBS.filter(function(j){ return j.active && !completedJobs[j.id]; }).length;
  var badge = document.getElementById('jobs-tile-badge');
  if(badge){ badge.textContent = count; badge.style.display = count > 0 ? 'inline-flex' : 'none'; }
}

function showOdPanel(id, btn){
  document.querySelectorAll('.od-panel').forEach(function(p){ p.style.display='none'; });
  document.querySelectorAll('.od-tab').forEach(function(b){ b.classList.remove('active'); });
  var p = document.getElementById(id); if(p) p.style.display='block';
  if(btn) btn.classList.add('active');
}

// ── Job info bar ──
function toggleOdEdit(){
  var bar=document.getElementById('od-info-bar'), edit=document.getElementById('od-info-edit');
  if(edit.style.display==='none'||edit.style.display===''){
    document.getElementById('od-job-num').value  = odJobNum==='——'?'':odJobNum;
    document.getElementById('od-job-name').value = odJobName;
    document.getElementById('od-billing').value  = odBilling==='——'?'':odBilling;
    edit.style.display='block'; bar.style.display='none';
  } else { edit.style.display='none'; bar.style.display='flex'; }
}

function saveOdInfo(){
  odJobNum  = document.getElementById('od-job-num').value.trim()  || '——';
  odJobName = document.getElementById('od-job-name').value.trim() || 'Olympic Discovery Trail';
  odBilling = document.getElementById('od-billing').value.trim()  || '——';
  document.getElementById('od-info-display').textContent =
    'Job #: '+odJobNum+' \u00b7 '+odJobName+' \u00b7 Billing: '+odBilling;
  document.getElementById('od-info-edit').style.display='none';
  document.getElementById('od-info-bar').style.display='flex';
}

// ── Auto-fill on login / panel open ──
function odAutoFill(){
  var today = new Date().toISOString().split('T')[0];
  var lead  = currentEmployee || '';
  ['bark-date','plant-date','ship-date','hydro-date','complete-date'].forEach(function(id){ odSetVal(id,today); });
  ['bark-lead','plant-lead','ship-lead','hydro-lead','complete-lead'].forEach(function(id){ odSetVal(id,lead); });
}

function odSetVal(id,val){ var el=document.getElementById(id); if(el) el.value=val; }
function odV(id){ var el=document.getElementById(id); return el?el.value:''; }
function odMeta(){ return 'Job #: '+odJobNum+' | Job: '+odJobName+' | Billing: '+odBilling; }

// ── Section tags ──
function addSecTag(selId, tagsId){
  var sel=document.getElementById(selId); if(!sel||!sel.value) return;
  var val=sel.value, tagsEl=document.getElementById(tagsId); if(!tagsEl) return;
  if(tagsEl.querySelector('[data-val="'+val+'"]')) return;
  var tag=document.createElement('span');
  tag.setAttribute('data-val',val);
  tag.style.cssText='display:inline-flex;align-items:center;gap:4px;background:var(--green-pale);color:var(--green-dark);border:1px solid var(--green-light);border-radius:20px;padding:3px 10px;font-size:0.78rem;font-weight:600;';
  tag.innerHTML=val+' <button onclick="this.parentElement.remove()" style="background:none;border:none;cursor:pointer;color:var(--green-dark);padding:0;font-size:0.9rem;line-height:1;">\u00d7</button>';
  tagsEl.appendChild(tag); sel.value='';
}

function getTagVals(tagsId){
  var el=document.getElementById(tagsId); if(!el) return '';
  return Array.from(el.querySelectorAll('[data-val]')).map(function(t){return t.getAttribute('data-val');}).join(', ');
}

// ── Generic submit ──
function odSubmit(btn, payload, okId){
  btn.disabled=true; btn.textContent='⏳ Submitting…';
  fetch(APPS_SCRIPT,{method:'POST',mode:'no-cors',headers:{'Content-Type':'text/plain'},body:JSON.stringify(payload)})
    .then(function(){ odSubmitOk(btn,okId); })
    .catch(function(){ odSubmitOk(btn,okId); }); // no-cors always resolves; treat catch as success too
}

function odSubmitOk(btn,okId){
  btn.textContent='✅ Submitted';
  var s=document.getElementById(okId); if(s) s.style.display='block';
  setTimeout(function(){ btn.disabled=false; btn.textContent=btn.getAttribute('data-label')||'📤 Submit Report'; if(s) s.style.display='none'; },4000);
}

