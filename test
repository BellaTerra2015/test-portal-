// INVOICE SCANNER — FIXED for Android Chrome
// Key fix: use FormData-free fetch with proper
// Anthropic headers. No CORS proxy needed since
// the Anthropic API supports cross-origin from
// browsers when the key is sent correctly.
// The real issue was missing anthropic-version
// header and beta header required for browser use.
// ═══════════════════════════════════════════════
let invoiceScanResults=[];

async function handleInvoiceUpload(e){
  const file=e.target.files[0];if(!file)return;

  // Show preview
  const reader=new FileReader();
  reader.onload=async(ev)=>{
    const b64=ev.target.result.split(',')[1];
    const mime=file.type;
    const prev=document.getElementById('inv-preview-content');
    if(mime.startsWith('image/'))prev.innerHTML=`<img src="${ev.target.result}" style="max-height:180px;object-fit:contain;border-radius:4px">`;
    else prev.innerHTML=`<div style="font-size:32px">📄</div><div style="font-size:12px;color:var(--ink3)">${file.name}</div>`;

    document.getElementById('inv-reading').style.display='block';
    document.getElementById('inv-results').style.display='none';
    document.getElementById('inv-actions').style.display='none';
    document.getElementById('inv-error').style.display='none';

    try {
      // Build message content
      const contentBlocks=[];
      if(mime.startsWith('image/')){
        contentBlocks.push({type:'image',source:{type:'base64',media_type:mime,data:b64}});
      } else {
        // PDF
        contentBlocks.push({type:'document',source:{type:'base64',media_type:'application/pdf',data:b64}});
      }
      contentBlocks.push({type:'text',text:'This is a vendor nursery invoice. Extract every line item plant entry. Return ONLY a JSON array — no markdown, no explanation, no backticks. Each object must have: {"common": "plant common name", "scientific": "scientific name or empty string", "form": "container size e.g. BR, plug, 4in, #1", "qty": number}. Normalize: BR=bare root, P=plug, 4"=4in. Skip non-plant items. If qty is unclear use 0.'});

      const resp=await fetch(ANTHROPIC_API,{
        method:'POST',
        headers:{
          'Content-Type':'application/json',
          'x-api-key':'',  // API key intentionally blank — routed via proxy or injected server-side
          'anthropic-version':'2023-06-01',
          'anthropic-dangerous-direct-browser-access':'true'
        },
        body:JSON.stringify({
          model:'claude-sonnet-4-20250514',
          max_tokens:1500,
          messages:[{role:'user',content:contentBlocks}]
        })
      });

      if(!resp.ok){
        const errBody=await resp.text();
        throw new Error(`API error ${resp.status}: ${errBody.slice(0,200)}`);
      }

      const data=await resp.json();
      const raw=data.content?.filter(c=>c.type==='text').map(c=>c.text).join('')||'';
      let parsed=[];
      try{
        // Strip any accidental markdown fences
        const cleaned=raw.replace(/```json|```/g,'').trim();
        parsed=JSON.parse(cleaned);
        if(!Array.isArray(parsed))parsed=[];
      }catch(pe){
        throw new Error('Could not parse response as JSON. Raw: '+raw.slice(0,300));
      }

      invoiceScanResults=parsed;
      renderInvoiceResults(parsed);

    } catch(err){
      document.getElementById('inv-error-msg').textContent=err.message||'Unknown error. Please try again.';
      document.getElementById('inv-error').style.display='flex';
    }
    document.getElementById('inv-reading').style.display='none';
  };
  reader.readAsDataURL(file);
}

function renderInvoiceResults(parsed){
  const el=document.getElementById('inv-results');const actions=document.getElementById('inv-actions');
  if(!parsed.length){el.innerHTML='<div class="nal nala"><span class="nali">⚠️</span><div>No plant entries found. Try a clearer photo with better lighting.</div></div>';el.style.display='block';return;}
  const jobId=document.getElementById('inv-job').value;
  let html=`<div style="font-weight:600;margin-bottom:8px">Claude read ${parsed.length} entries — confirm before saving:</div>
    <table class="tbl"><thead><tr><th>#</th><th>Common Name</th><th>Matched Species</th><th>Container</th><th>Qty</th><th>Edit Qty</th></tr></thead><tbody>`;
  parsed.forEach((row,i)=>{
    const q=(row.common||'').toLowerCase();
    const best=masterSpecies.reduce((best,sp)=>{
      const sc=sp.common.toLowerCase();
      if(sc===q||sc.includes(q)||q.includes(sc.slice(0,5)))return(!best||(sc.length>best.common.length))?sp:best;
      return best;
    },null);
    const contNorm={'br':'bare root','bare root':'bare root','p':'plug','plug':'plug','4in':'4in','4"':'4in','#1':'#1','#2':'#2','#3':'#3','#5':'#5'}[((row.form||'').toLowerCase().trim())]||row.form||'bare root';
    html+=`<tr>
      <td style="font-family:'DM Mono',monospace;color:var(--ink3)">${i+1}</td>
      <td style="font-size:12px"><b>${row.common||'?'}</b>${row.scientific?`<br><em style="font-size:10px;color:var(--ink3)">${row.scientific}</em>`:''}</td>
      <td style="font-size:11px">${best?`<select id="scan-sp-${i}" style="font-size:11px;padding:3px;border:1px solid var(--brd);border-radius:3px;background:var(--paper)">${masterSpecies.map(s=>`<option value="${s.id}" ${s.id===best.id?'selected':''}>${s.common}</option>`).join('')}<option value="">— Not in list —</option></select>`:'<span style="color:var(--red2);font-size:11px">No match</span>'}</td>
      <td><select id="scan-cont-${i}" style="font-size:11px;padding:3px;border:1px solid var(--brd);border-radius:3px;background:var(--paper)">${['plug','4in','bare root','live stake','#1','#2','#3','#5'].map(s=>`<option value="${s}" ${s===contNorm?'selected':''}>${s}</option>`).join('')}</select></td>
      <td style="font-family:'DM Mono',monospace;font-weight:600">${row.qty||0}</td>
      <td><input type="number" id="scan-qty-${i}" value="${row.qty||0}" min="0" style="width:60px;font-size:12px;padding:3px;border:1px solid var(--brd);border-radius:3px"></td>
    </tr>`;
  });
