// ── Clackamas monthly reminder (1st of month) ──
function checkClackamasReminder(){
  var today = new Date();
  if(today.getDate() !== 1) return;
  var key = 'clackamas_reminder_' + today.getFullYear() + '_' + (today.getMonth()+1);
  if(localStorage.getItem(key)) return;
  localStorage.setItem(key, '1');
  // Show banner
  var banner = document.getElementById('clackamas-reminder-banner');
  if(banner) banner.style.display='flex';
  // Send email to Rena
  var payload = {
    type: 'Clackamas_Photo_Reminder',
    to: 'Rena@1BellaTerra.com',
    subject: 'Reminder — Submit Clackamas Water Hydrant Photos',
    body: 'Monthly reminder: Today is the 1st. Please submit Clackamas Water hydrant photos to the office.',
    employee: currentEmployee
  };
  fetch(APPS_SCRIPT,{method:'POST',mode:'no-cors',headers:{'Content-Type':'text/plain'},body:JSON.stringify(payload)})
    .catch(function(){});
}

