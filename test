        const job=jobs.find(j=>j.id===e.jobAlloc);
        return`<tr><td><span class="loc-pill ${LOC_CLASS[e.location]||'loc-vendor'}">${LOC_LABELS[e.location]||e.location}</span></td>
          <td style="font-family:'DM Mono',monospace;font-size:11px">${e.container}</td>
          <td style="font-family:'DM Mono',monospace;font-weight:600">${parseInt(e.qty)||0}</td>
          <td><span class="chip ${e.origin==='grown'?'cg':'cb2'}">${({grown:'BT Grown',bare_root_purchase:'Bare Root',vendor:'Vendor',carryover:'Carryover',job_return:'Job Return'}[e.origin])||e.origin}</span></td>
          <td style="font-size:11px;font-family:'DM Mono',monospace">${e.dateAdded||'—'}</td>
          <td style="font-size:11px">${job?`<span style="background:${job.color};color:#fff;padding:1px 6px;border-radius:3px;font-size:10px">${job.name}</span>`:''}</td>
          <td>${nurseryEditMode?`<button class="nbtn nbsm" style="background:var(--red-lt);border-color:var(--red3);color:var(--red2)" onclick="deleteStockEntry('${e.id}','${s.common}',${parseInt(e.qty)||0})">🗑 Delete</button>`:'<span style="font-size:10px;color:var(--ink4)">🔒</span>'}</td>
        </tr>`;
      }).join('')}</tbody></table></div></div>`;
